```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.js.map

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Logs and temp files
*.log
*.tmp
*.swp

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.git/refs/original/
**/.gitignore
!.gitignore
```